# ──────────────────────────────────────────────────────────────
# Vision Properties — environment configuration
# Copy this file to .env.local and fill in your Supabase values.
# ──────────────────────────────────────────────────────────────

# Supabase project URL (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Supabase SERVICE ROLE key (Project Settings → API → service_role).
# Server-only. NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret used to sign session cookies. Use a long random string.
# Generate one with: openssl rand -base64 48
AUTH_SECRET=change-me-to-a-long-random-secret
